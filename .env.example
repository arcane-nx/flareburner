# flareburner configuration — copy to .env and edit.
# All values are optional; sensible defaults are shown.

# Port the HTTP API listens on.
PORT=4001

# Optional API key. If set, POST /v1 requires:
#   X-API-Key: <key>            (or)   Authorization: Bearer <key>
# Leave empty to keep the API open.
API_KEY=

# Number of warm Chrome instances (max concurrent requests).
POOL_SIZE=1

# Run Chrome headless. Cloudflare is harder to beat headless; keep false
# unless you know your target doesn't challenge.
HEADLESS=false

# Navigation + Cloudflare-wait timeout, in milliseconds.
NAV_TIMEOUT=60000

# URL used when a request omits "url".
DEFAULT_URL=
